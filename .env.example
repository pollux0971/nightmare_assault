# Nightmare Assault API Configuration
# 將此檔案複製為 .env 並填入你的 API keys

# ============================================================================
# API Provider Configuration
# ============================================================================
# 選擇你的 LLM Provider (openrouter, anthropic, openai, google, cohere)
NIGHTMARE_API_PROVIDER=openrouter

# 選擇模型
NIGHTMARE_API_MODEL=anthropic/claude-3.5-sonnet

# 最大 token 數量
NIGHTMARE_API_MAX_TOKENS=100000

# ============================================================================
# API Keys (填入你使用的 provider 的 key)
# ============================================================================

# OpenRouter API Key (推薦 - 支援多種模型)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Anthropic API Key (直接使用 Claude)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI API Key
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Google AI API Key
GOOGLE_API_KEY=YOUR_KEY_HERE

# Cohere API Key
COHERE_API_KEY=YOUR_KEY_HERE

# ============================================================================
# Optional: Custom Base URL (僅在需要時設定)
# ============================================================================
# NIGHTMARE_API_BASE_URL=https://custom-endpoint.com/v1

# ============================================================================
# Debug Settings (可選)
# ============================================================================
# NIGHTMARE_DEBUG=false
# NIGHTMARE_LOG_API_KEYS=false
# NIGHTMARE_LOG_REQUESTS=false
