package integration

import (
	"context"
	"errors"
	"strings"
	"testing"
	"time"

	"github.com/nightmare-assault/nightmare-assault/internal/api/client"
	"github.com/nightmare-assault/nightmare-assault/internal/trinity"
)

// TestEpic9_ProviderErrors tests handling of various provider errors
// 測試 Provider 錯誤：API 超時、rate limit、錯誤響應
func TestEpic9_ProviderErrors(t *testing.T) {
	t.Parallel()

	testCases := []struct {
		name          string
		providerError error
		expectError   bool
		errorContains string
	}{
		{
			name:          "API_Timeout",
			providerError: ErrMockTimeout,
			expectError:   true,
			errorContains: "timeout",
		},
		{
			name:          "Rate_Limit",
			providerError: ErrMockRateLimit,
			expectError:   true,
			errorContains: "rate limit",
		},
		{
			name:          "Invalid_Model",
			providerError: ErrMockInvalidModel,
			expectError:   true,
			errorContains: "invalid model",
		},
		{
			name:          "API_Error",
			providerError: ErrMockAPIError,
			expectError:   true,
			errorContains: "API error",
		},
		{
			name:          "Network_Error",
			providerError: ErrMockNetworkError,
			expectError:   true,
			errorContains: "network error",
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			// Create router with mock providers
	thinkingProvider := NewMockProvider("Thinking response")
	reactiveProvider := NewMockProvider("Reactive response")
	rapidProvider := NewMockProvider("Rapid response")

	router := trinity.NewTrinityRouterWithProviders(
		thinkingProvider,
		reactiveProvider,
		rapidProvider,
		true, // fallback enabled
		make(map[string]trinity.TierLevel), // no overrides
	)

	ctx := context.Background()

	testCases := []struct {
		name     string
		messages []client.Message
		agent    string
	}{
		{
			name:     "Empty_Messages",
			messages: []client.Message{},
			agent:    "judge",
		},
		{
			name: "Empty_Content",
			messages: []client.Message{
				{Role: "user", Content: ""},
			},
			agent: "choice",
		},
		{
			name: "Very_Long_Message",
			messages: []client.Message{
				{Role: "user", Content: strings.Repeat("a", 10000)},
			},
			agent: "narration",
		},
		{
			name: "Special_Characters",
			messages: []client.Message{
				{Role: "user", Content: "測試中文\n<think>標籤</think>\n特殊符號: !@#$%^&*()"},
			},
			agent: "judge",
		},
		{
			name: "Unicode_Emoji",
			messages: []client.Message{
				{Role: "user", Content: "Test with emoji 🎮🔥💀👻"},
			},
			agent: "dream",
		},
		{
			name: "Newlines_And_Tabs",
			messages: []client.Message{
				{Role: "user", Content: "Line 1\nLine 2\tTabbed\r\nWindows line ending"},
			},
			agent: "npc",
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			// Request should not panic
			resp, err := router.Route(ctx, tc.agent, tc.messages)

			// Log result
			if err != nil {
				t.Logf("Edge case '%s' resulted in error: %v", tc.name, err)
			} else {
				t.Logf("Edge case '%s' handled successfully", tc.name)
				AssertNotEqual(t, nil, resp, "Response should not be nil on success")
			}

			// Test should not panic - if we get here, edge case is handled
		})
	}
}

// TestEpic9_RecoveryFromErrors tests system recovery after errors
// 測試錯誤恢復：系統在錯誤後能否正常恢復
func TestEpic9_RecoveryFromErrors(t *testing.T) {
	t.Parallel()

	// Create router with mock providers
	thinkingProvider := NewMockProvider("Thinking response")
	reactiveProvider := NewMockProvider("Reactive response")
	rapidProvider := NewMockProvider("Rapid response")

	router := trinity.NewTrinityRouterWithProviders(
		thinkingProvider,
		reactiveProvider,
		rapidProvider,
		true, // fallback enabled
		make(map[string]trinity.TierLevel), // no overrides
	)

	ctx := context.Background()
	messages := TestMessages("user", "Test message")

	// Test recovery sequence
	t.Run("Recovery_Sequence", func(t *testing.T) {
		// 1. Normal request
		resp1, err1 := router.Route(ctx, "judge", messages)
		AssertNoError(t, err1, "First request should succeed")
		AssertNotEqual(t, nil, resp1, "First response should not be nil")

		// 2. Simulate error (with current mock, can't actually fail)
		// This documents the expected recovery behavior

		// 3. Recovery - next request should work
		resp2, err2 := router.Route(ctx, "judge", messages)
		AssertNoError(t, err2, "Recovery request should succeed")
		AssertNotEqual(t, nil, resp2, "Recovery response should not be nil")

		// 4. Verify metrics show recovery
		metrics := router.GetMetricsSummary()
		t.Logf("Metrics after recovery: Total=%d, Success=%.2f%%",
			metrics.ThinkingStats.TotalRequests,
			metrics.ThinkingStats.SuccessRate*100)
	})

	t.Run("Metrics_Reset_After_Errors", func(t *testing.T) {
		// Reset metrics
		router.ResetMetrics()

		// Make requests
		for i := 0; i < 10; i++ {
			router.Route(ctx, "choice", messages)
		}

		// Verify metrics are tracked
		metrics := router.GetMetricsSummary()
		AssertTrue(t, metrics.ReactiveStats.TotalRequests == 10,
			"Should track all requests after reset")

		// Reset again
		router.ResetMetrics()
		metricsAfterReset := router.GetMetricsSummary()
		AssertEqual(t, int64(0), metricsAfterReset.ReactiveStats.TotalRequests,
			"Metrics should reset to zero")
	})
}

