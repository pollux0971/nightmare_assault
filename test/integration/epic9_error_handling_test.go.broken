// TestEpic9_GracefulDegradation tests graceful degradation behavior
// 測試優雅降級：部分功能失敗時系統仍能運作
func TestEpic9_GracefulDegradation(t *testing.T) {
	t.Parallel()

	routerConfig := trinity.RouterConfig{
		ThinkingProvider: trinity.ProviderTierConfig{
			ProviderID:  "mock",
			Model:       "thinking",
			MaxTokens:   16000,
			Temperature: 0.4,
		},
		ReactiveProvider: trinity.ProviderTierConfig{
			ProviderID:  "mock",
			Model:       "reactive",
			MaxTokens:   8000,
			Temperature: 0.7,
		},
		RapidProvider: trinity.ProviderTierConfig{
			ProviderID:  "mock",
			Model:       "rapid",
			MaxTokens:   4000,
			Temperature: 0.9,
		},
		FallbackEnabled:    true,
		AgentTierOverrides: make(map[string]trinity.TierLevel),
	}

	router, err := trinity.NewTrinityRouter(routerConfig)
	AssertNoError(t, err, "Failed to create router")

	ctx := context.Background()
	messages := TestMessages("user", "Degradation test")

	t.Run("Metrics_Unavailable", func(t *testing.T) {
		// Even if metrics fail, routing should work
		resp, err := router.Route(ctx, "judge", messages)
		AssertNoError(t, err, "Routing should work even if metrics fail")
		AssertNotEqual(t, nil, resp, "Should get response")

		// Getting metrics should not panic
		metrics := router.GetMetricsSummary()
		t.Logf("Metrics available: %+v", metrics)
	})

	t.Run("ThinkingTags_Extraction_Fails", func(t *testing.T) {
		// If thinking tag extraction fails, should still return response
		// Create malformed thinking content
		malformed := "<think>Unclosed thinking tag\nContent here"
		messagesWithMalformed := []client.Message{
			{Role: "user", Content: "test"},
			{Role: "assistant", Content: malformed},
		}

		resp, err := router.Route(ctx, "judge", messagesWithMalformed)

		// Should handle gracefully
		if err != nil {
			t.Logf("Malformed thinking tags resulted in error: %v", err)
		} else {
			t.Log("Malformed thinking tags handled gracefully")
			AssertNotEqual(t, nil, resp, "Should get response")
		}
	})
}

// TestEpic9_ErrorMessages tests error message clarity
// 測試錯誤訊息清晰度：確保錯誤訊息有幫助
func TestEpic9_ErrorMessages(t *testing.T) {
	t.Parallel()

	testCases := []struct {
		name             string
		setupConfig      func() trinity.RouterConfig
		expectedErrorMsg string
	}{
		{
			name: "Missing_Provider_Config",
			setupConfig: func() trinity.RouterConfig {
				return trinity.RouterConfig{
					// Missing ThinkingProvider
					ReactiveProvider: trinity.ProviderTierConfig{
						ProviderID: "mock",
						Model:      "reactive",
					},
					RapidProvider: trinity.ProviderTierConfig{
						ProviderID: "mock",
						Model:      "rapid",
					},
				}
			},
			expectedErrorMsg: "provider",
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			config := tc.setupConfig()
			_, err := trinity.NewTrinityRouter(config)

			if err != nil {
				// Verify error message is helpful
				errorMsg := err.Error()
				t.Logf("Error message: %s", errorMsg)

				// Error should not be generic
				AssertFalse(t, errorMsg == "error" || errorMsg == "failed",
					"Error message should be descriptive")

				// Should contain expected keyword
				if tc.expectedErrorMsg != "" {
					containsKeyword := strings.Contains(strings.ToLower(errorMsg),
						strings.ToLower(tc.expectedErrorMsg))
					AssertTrue(t, containsKeyword,
						"Error message should mention: "+tc.expectedErrorMsg)
				}
			}
		})
	}
}

// mockErrorProvider simulates a provider that returns specific errors
type mockErrorProvider struct {
	err error
}

func (m *mockErrorProvider) SendMessage(ctx context.Context, messages []client.Message) (*client.Response, error) {
	return nil, m.err
}

// newMockErrorProvider creates a provider that always returns the given error
func newMockErrorProvider(err error) *mockErrorProvider {
	return &mockErrorProvider{err: err}
}

// Common errors for testing
var (
	errRetryable    = errors.New("retryable error")
	errNonRetryable = errors.New("non-retryable error")
	errPermanent    = errors.New("permanent failure")
)
